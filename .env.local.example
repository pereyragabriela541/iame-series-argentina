# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Sitio (SEO / sitemap — opcional si usás el dominio de Vercel)
NEXT_PUBLIC_SITE_URL=https://iame-series-argentina.vercel.app

# Email — Resend (llega a Gmail y Outlook/Live)
# 1) resend.com → Domains → agregar bsproyect.com
# 2) Cloudflare → DNS → pegar los registros que da Resend → esperar Verified
# 3) API key + variables en Vercel → redeploy
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=IAME Series Argentina <registracion@bsproyect.com>
EMAIL_NOTIFY_TO=iameseriesarg@gmail.com

# Email — Gmail SMTP (fallback si no hay RESEND_API_KEY; Outlook/Live suele bloquearlo)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=iameseriesarg@gmail.com
EMAIL_SMTP_PASS=your_gmail_app_password
